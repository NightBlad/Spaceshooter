# This .gitignore file is designed for Unity projects
# https://github.com/github/gitignore/blob/main/Unity.gitignore

# ============================================
# UNITY-SPECIFIC DIRECTORIES
# ============================================
/Library/
/Temp/
Logs/
/[Bb]uild/
/[Bb]uilds/
/[Oo]ut/
/[Pp]ublish/
/ExportedObj/

# Uncomment this line if using Cloud Save
# ! /[Ll]ibrary/CloudBackup

# Memory Captures
/[Mm]emoryCaptures/

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ============================================
# ASSET META FILES
# ============================================
# Asset meta data should only be in the repository when it is a new file
/[Aa]ssets/**/*.questionable
/[Aa]ssets/**/*.meta
!/[Aa]ssets/**/*.meta

# ============================================
# IDE CACHE DIRECTORIES
# ============================================
ExportedObj/
.consulo/
.gradle/
.vs/
.vscode/
.idea/

# ============================================
# IDE CONFIGURATION FILES
# ============================================
*.csproj
*.unityproj
*.sln
*.sln.iml
*.suo
*.tmp
*.user
*.userprefs

# ============================================
# DEBUG & CRASH FILES
# ============================================
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Mono Auto Generated Files
mono_crash.*

# Unity3D generated file on crash reports
sysinfo.txt
sysinfo.txt.meta

# ============================================
# JETBRAINS RIDER
# ============================================
# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# ============================================
# VISUAL STUDIO CODE
# ============================================
.history/
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ============================================
# LOGS
# ============================================
/[Ll]ogs/
*.log
*.logs

# ============================================
# EXTERNAL DLLs (Uncomment if needed)
# ============================================
# /[Aa]ssets/Plugins/x86/
# /[Aa]ssets/Plugins/x86_64/

# ============================================
# OPERATING SYSTEM FILES
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# BUILD ARTIFACTS
# ============================================
dist/
bin/
obj/

# BVE Trainsim specific
.localhistory/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backup files
*.bak
*.backup
*~

# IDE files
*.swp
*.swo
*.swn
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Environment files
.env
.env.local
.env.*.local

# DLL files
*.dll

# Additional Unity specific
Builds/
Temp/
Library/
Logs/
obj/
